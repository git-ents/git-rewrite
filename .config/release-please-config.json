{
  "pull-request-header": "Release",
  "changelog-path": "CHANGELOG.md",
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "draft": false,
  "include-component-in-tag": true,
  "include-v-in-tag": true,
  "prerelease": true,
  "release-type": "rust",
  "initial-version": "0.0.1",
  "separate-pull-requests": false,
  "draft-pull-request": true,
  "group-pull-request-title-pattern": "chore(release): generate new versions on `${branch}`",
  "pull-request-footer": "This release was generated with [Release Please](https://github.com/googleapis/release-please).",
  "packages": {
    ".": {
      "release-as": "0.0.2",
      "include-component-in-tag": false,
      "exclude-paths": ["plumbing/"]
    },
    "plumbing/git-filter-tree": {
      "release-as": "0.0.2",
      "extra-files": [
        {
          "type": "toml",
          "path": "Cargo.toml",
          "jsonpath": "$.dependencies.git-filter-tree.version"
        }
      ]
    }
  },
  "plugins": [{ "type": "sentence-case" }],
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json"
}
